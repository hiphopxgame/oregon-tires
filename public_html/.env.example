# Oregon Tires — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4

# ─── SMTP (PHPMailer) ────────────────────────────────────────────────────────
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=contact@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=contact@example.com
SMTP_FROM_NAME="Your Business Name"
CONTACT_EMAIL=you@example.com
SMTP_DEBUG=0

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://yourdomain.com
APP_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# ─── Google OAuth (optional — enables "Sign in with Google") ────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://oregon.tires/api/auth/google-callback.php

# ─── Shared Kits (server paths) ─────────────────────────────────────────
# Local dev: auto-detected from directory structure
# Server: /home/hiphopwo/shared/{kit-name}
FORM_KIT_PATH=/home/hiphopwo/shared/form-kit
COMMERCE_KIT_PATH=/home/hiphopwo/shared/commerce-kit
MEMBER_KIT_PATH=/home/hiphopwo/shared/member-kit
ENGINE_KIT_PATH=/home/hiphopwo/shared/engine-kit

# ─── Error Tracking (Sentry — optional) ──────────────────────────────────
SENTRY_DSN=
SENTRY_DSN_JS=

# ─── SEO / Search Platform Verification ──────────────────────────────────
# Get verification codes from Google Search Console and Bing Webmaster Tools
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# ─── IndexNow (Bing fast indexing) ───────────────────────────────────────
# Generate: php -r "echo bin2hex(random_bytes(16)) . PHP_EOL;"
# Also create: public_html/{key}.txt containing the key
INDEXNOW_KEY=

# ─── Cross-Site Sync ───────────────────────────────────────────────────────
# API key for reporting activity to HipHop.World network hub
# Get from HHW admin panel or generate via: php deploy/generate-site-key.php --site=oregontires
SYNC_API_KEY=
