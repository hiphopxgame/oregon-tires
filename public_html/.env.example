# Oregon Tires — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4

# ─── SMTP (PHPMailer) ────────────────────────────────────────────────────────
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=contact@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=contact@example.com
SMTP_FROM_NAME="Your Business Name"
CONTACT_EMAIL=you@example.com
SMTP_DEBUG=0

# ─── IMAP (Inbound Email) ──────────────────────────────────────────────────────
IMAP_HOST=mail.oregon.tires
IMAP_PORT=993
IMAP_USER=contact@oregon.tires
IMAP_PASSWORD=your_imap_password
IMAP_ENCRYPTION=ssl

# ─── WhatsApp Business API (FREE — Meta Cloud API) ──────────────────────────
# Setup: developers.facebook.com → Create App → Add WhatsApp product
# Free: 1,000 service conversations/month
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ─── Twilio SMS (optional fallback if WhatsApp unavailable) ──────────────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ─── Google Places API (reviews + market intel map) ──────────────────────────
GOOGLE_PLACES_API_KEY=

# ─── PayPal (care plans + payments) ──────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

# ─── Stripe (optional alternative payment processor) ─────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://yourdomain.com
APP_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# ─── Google OAuth (optional — enables "Sign in with Google") ────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://oregon.tires/api/auth/google-callback.php

# ─── Shared Kits (server paths) ─────────────────────────────────────────
# Local dev: auto-detected from directory structure
# Server: /home/hiphopwo/shared/{kit-name}
FORM_KIT_PATH=/home/hiphopwo/shared/form-kit
COMMERCE_KIT_PATH=/home/hiphopwo/shared/commerce-kit
MEMBER_KIT_PATH=/home/hiphopwo/shared/member-kit
ENGINE_KIT_PATH=/home/hiphopwo/shared/engine-kit

# ─── Error Tracking (Sentry — optional) ──────────────────────────────────
SENTRY_DSN=
SENTRY_DSN_JS=

# ─── SEO / Search Platform Verification ──────────────────────────────────
# Get verification codes from Google Search Console and Bing Webmaster Tools
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# ─── IndexNow (Bing fast indexing) ───────────────────────────────────────
# Generate: php -r "echo bin2hex(random_bytes(16)) . PHP_EOL;"
# Also create: public_html/{key}.txt containing the key
INDEXNOW_KEY=

# ─── Web Push (VAPID) ───────────────────────────────────────────────────
# Subject for VAPID authentication (mailto: or https: URL)
# VAPID keys are auto-generated and stored in DB via cli/generate-vapid-keys.php
VAPID_SUBJECT=mailto:contact@yourdomain.com

# ─── Google Calendar Sync ──────────────────────────────────────────────────
# Service account JSON file path (relative to project root or absolute)
GOOGLE_SERVICE_ACCOUNT_JSON=google-service-account.json
# Shared Google Calendar ID (found in Calendar Settings → Integrate calendar)
GOOGLE_CALENDAR_ID=
# Enable/disable automatic calendar sync (0 = off, 1 = on)
GOOGLE_CALENDAR_SYNC_ENABLED=0

# ─── Google Business Profile ──────────────────────────────────────────────
# GBP Account and Location IDs for API management
GOOGLE_GBP_ACCOUNT_ID=
GOOGLE_GBP_LOCATION_ID=

# ─── Cross-Site Sync ───────────────────────────────────────────────────────
# API key for reporting activity to HipHop.World network hub
# Get from HHW admin panel or generate via: php deploy/generate-site-key.php --site=oregontires
SYNC_API_KEY=
