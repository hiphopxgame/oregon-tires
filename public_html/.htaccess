# --- Force HTTPS ---
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # --- Redirect www to non-www ---
    RewriteCond %{HTTP_HOST} ^www\.oregon\.tires$ [NC]
    RewriteRule ^(.*)$ https://oregon.tires/$1 [L,R=301]

    # CLEAN URLs: token-based customer pages
    # 301 redirect old ?token= format
    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^inspection$ /inspection/%1? [R=301,L]
    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^inspection\.php$ /inspection/%1? [R=301,L]

    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^approve$ /approve/%1? [R=301,L]
    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^approve\.php$ /approve/%1? [R=301,L]

    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^cancel$ /cancel/%1? [R=301,L]
    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^cancel\.php$ /cancel/%1? [R=301,L]

    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^reschedule$ /reschedule/%1? [R=301,L]
    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^reschedule\.php$ /reschedule/%1? [R=301,L]

    # Internal rewrites: /page/TOKEN → page.php?token=TOKEN
    RewriteRule ^inspection/([a-f0-9]+)/?$ inspection.php?token=$1 [L,QSA]
    RewriteRule ^approve/([a-f0-9]+)/?$ approve.php?token=$1 [L,QSA]
    RewriteRule ^cancel/([a-f0-9]+)/?$ cancel.php?token=$1 [L,QSA]
    RewriteRule ^reschedule/([a-f0-9]+)/?$ reschedule.php?token=$1 [L,QSA]

    # 301 redirect old root js/ → admin/js/ (ot-charts.js moved)
    RewriteRule ^js/(.+)$ /admin/js/$1 [R=301,L]

    # Dashboard: /admin → redirect to /members
    RewriteRule ^admin/?$ /members [R=301,L]

    # Dashboard: /members → serve admin dashboard
    RewriteRule ^members/?$ admin/index.html [L]

    # --- Clean URLs: strip .php extension ---
    # 301 redirect /page.php → /page (SEO + UX)
    RewriteCond %{THE_REQUEST} \s/+(.+)\.php[\s?] [NC]
    RewriteCond %{THE_REQUEST} !/api/ [NC]
    RewriteRule ^ /%1 [R=301,L]

    # Internal rewrite /page → page.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.+)$ $1.php [L,QSA]
</IfModule>

# --- Directory Index ---
DirectoryIndex index.html index.php

# --- Error Pages ---
ErrorDocument 404 /404.html
ErrorDocument 403 /index.html

# --- Block access to dotfiles (except this .htaccess) ---
<FilesMatch "^\.ht">
    Require all denied
</FilesMatch>

# --- Prevent directory listing ---
Options -Indexes

# --- Security Headers ---
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://hiphop.world https://connect.facebook.net https://googleads.g.doubleclick.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.google-analytics.com https://*.googletagmanager.com https://www.facebook.com https://*.doubleclick.net; connect-src 'self' https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://hiphop.world https://www.facebook.com; frame-src https://www.google.com; font-src 'self';"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=(self), payment=()"
</IfModule>

# Hide server info
ServerSignature Off
<IfModule mod_headers.c>
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# --- Enable GZIP compression ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

# --- Cache static assets ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# --- Block access to sensitive files ---
<FilesMatch "(\.sql|\.env|\.git|package\.json|composer\.(json|lock)|\.bak|\.tmp)$">
    Require all denied
</FilesMatch>

# --- Block CLI scripts and admin-only PHP from web access ---
<FilesMatch "^(send-setup-emails\.php)$">
    Require all denied
</FilesMatch>

# --- Block /cli/ directory ---
<IfModule mod_rewrite.c>
    RewriteRule ^cli/ - [F,L]
</IfModule>
