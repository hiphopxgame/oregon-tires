# --- Force HTTPS ---
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Cloudflare Real IP Restoration
    <IfModule mod_remoteip.c>
        RemoteIPHeader CF-Connecting-IP
    </IfModule>

    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # --- Redirect www to non-www ---
    RewriteCond %{HTTP_HOST} ^www\.oregon\.tires$ [NC]
    RewriteRule ^(.*)$ https://oregon.tires/$1 [L,R=301]

    # CLEAN URLs: token-based customer pages
    # 301 redirect old ?token= format
    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^inspection$ /inspection/%1? [R=301,L]
    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^inspection\.php$ /inspection/%1? [R=301,L]

    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^approve$ /approve/%1? [R=301,L]
    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^approve\.php$ /approve/%1? [R=301,L]

    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^cancel$ /cancel/%1? [R=301,L]
    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^cancel\.php$ /cancel/%1? [R=301,L]

    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^reschedule$ /reschedule/%1? [R=301,L]
    RewriteCond %{QUERY_STRING} ^token=([a-f0-9]+)$ [NC]
    RewriteRule ^reschedule\.php$ /reschedule/%1? [R=301,L]

    # Internal rewrites: /page/TOKEN → page.php?token=TOKEN
    RewriteRule ^inspection/([a-f0-9]+)/?$ inspection.php?token=$1 [L,QSA]
    RewriteRule ^approve/([a-f0-9]+)/?$ approve.php?token=$1 [L,QSA]
    RewriteRule ^cancel/([a-f0-9]+)/?$ cancel.php?token=$1 [L,QSA]
    RewriteRule ^reschedule/([a-f0-9]+)/?$ reschedule.php?token=$1 [L,QSA]

    # Dashboard alias: /dashboard → members.php (unified dashboard)
    RewriteRule ^dashboard/?$ members.php [L,QSA]

    # Member password reset: /reset-password/TOKEN → member/reset-password.php?token=TOKEN
    RewriteRule ^reset-password/([a-f0-9]+)/?$ member/reset-password.php?token=$1 [L,QSA]

    # Blog post clean URLs: /blog/SLUG → blog-post.php?slug=SLUG
    RewriteRule ^blog/([a-z0-9-]+)/?$ blog-post.php?slug=$1 [L,QSA]

    # Promotions clean URLs: /promotions/{id} → promotions.php?id={id}
    RewriteCond %{QUERY_STRING} ^id=([0-9]+)$
    RewriteRule ^promotions$ /promotions/%1? [R=301,L]
    RewriteCond %{QUERY_STRING} ^id=([0-9]+)$
    RewriteRule ^promotions\.php$ /promotions/%1? [R=301,L]

    RewriteRule ^promotions/([0-9]+)/?$ promotions.php?id=$1 [L,QSA]

    # Dynamic sitemap: /sitemap.xml → api/sitemap.php
    RewriteRule ^sitemap\.xml$ api/sitemap.php [L]

    # 301 redirect old root js/ → admin/js/ (ot-charts.js moved)
    RewriteRule ^js/(.+)$ /admin/js/$1 [R=301,L]

    # Admin dashboard
    RewriteRule ^admin/?$ admin/index.html [L]

    # API Versioning: /api/v1/* → /api/* alias
    RewriteRule ^api/v1/(.+)$ /api/$1 [L,QSA]

    # =============================================
    # WebP/AVIF Content Negotiation
    # =============================================
    # Serve AVIF if browser supports and .avif file exists alongside original
    RewriteCond %{HTTP_ACCEPT} image/avif [NC]
    RewriteCond %{REQUEST_FILENAME} (.+)\.(jpe?g|png)$
    RewriteCond %1.avif -f
    RewriteRule (.+)\.(jpe?g|png)$ $1.avif [T=image/avif,L]

    # Serve WebP if browser supports and .webp file exists alongside original
    RewriteCond %{HTTP_ACCEPT} image/webp [NC]
    RewriteCond %{REQUEST_FILENAME} (.+)\.(jpe?g|png)$
    RewriteCond %1.webp -f
    RewriteRule (.+)\.(jpe?g|png)$ $1.webp [T=image/webp,L]

    <IfModule mod_headers.c>
        <FilesMatch "\.(jpe?g|png)$">
            Header append Vary Accept
        </FilesMatch>
    </IfModule>

    # Block sensitive PHP files before clean-URL rewrite
    RewriteRule ^config\.php$ - [F,L]
    RewriteRule ^config$ - [F,L]

    # --- Clean URLs: strip .php extension ---
    # 301 redirect /page.php → /page (SEO + UX)
    RewriteCond %{THE_REQUEST} \s/+(.+)\.php[\s?] [NC]
    RewriteCond %{THE_REQUEST} !/api/ [NC]
    RewriteRule ^ /%1 [R=301,L]

    # Internal rewrite /page → page.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.+)$ $1.php [L,QSA]
</IfModule>

# --- Directory Index ---
DirectoryIndex index.html index.php

# --- Error Pages ---
ErrorDocument 404 /404.html
ErrorDocument 403 /index.html

# --- Block access to dotfiles (except this .htaccess) ---
<FilesMatch "^\.(?!htaccess)">
    Require all denied
</FilesMatch>

# --- Prevent directory listing ---
Options -Indexes

# --- Security Headers ---
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://hiphop.world https://connect.facebook.net https://googleads.g.doubleclick.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.google-analytics.com https://*.googletagmanager.com https://www.facebook.com https://*.doubleclick.net; connect-src 'self' https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://hiphop.world https://www.facebook.com; frame-src https://www.google.com; font-src 'self';"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=(self), payment=()"
</IfModule>

# Hide server info
ServerSignature Off
<IfModule mod_headers.c>
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# --- Enable GZIP compression ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml application/xml image/svg+xml
</IfModule>

# --- Cache static assets ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/avif "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

<IfModule mod_headers.c>
    Header append Vary "Accept-Encoding"
</IfModule>

# --- Block access to sensitive files ---
<FilesMatch "^\.env|\.sql$|\.git|^package(-lock)?\.json$|^composer\.(json|lock)$|\.bak$|\.tmp$">
    Require all denied
</FilesMatch>

# --- Block CLI scripts and admin-only PHP from web access ---
<FilesMatch "^(send-setup-emails\.php)$">
    Require all denied
</FilesMatch>

# --- Block /cli/ directory ---
<IfModule mod_rewrite.c>
    RewriteRule ^cli/ - [F,L]
</IfModule>
