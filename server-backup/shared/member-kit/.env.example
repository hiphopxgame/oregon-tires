# ── Database ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hiphopwo_sitename
DB_USER=hiphopwo_sitename
DB_PASSWORD=secret

# ── Member Kit Mode ──────────────────────────────────────────────────────
# "independent" = own members table | "hw" = shared hiphop.world users table
MEMBER_MODE=independent
SITE_URL=https://mysite.com
SITE_NAME="My Site"

# Required for HW mode only:
# MEMBER_TABLE_PREFIX=_mysite

# ── Session ──────────────────────────────────────────────────────────────
SESSION_NAME=member_session
SESSION_LIFETIME=86400

# ── SMTP (password reset & verification emails) ─────────────────────────
SMTP_HOST=mail.hiphop.world
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=noreply@hiphop.world
SMTP_PASSWORD=secret
SMTP_FROM=noreply@mysite.com
SMTP_FROM_NAME="My Site"
SMTP_DEBUG=0

# ── SSO (optional — enables single sign-on) ─────────────────────────────
# SSO_CLIENT_ID=hpw_...
# SSO_CLIENT_SECRET=sk_...
# SSO_REDIRECT_URI=https://mysite.com/api/member/sso-callback.php
# SSO_AUTH_URL=https://hiphop.world/oauth/authorize
# SSO_TOKEN_URL=https://hiphop.world/oauth/token
# SSO_USERINFO_URL=https://hiphop.world/oauth/userinfo
# SSO_BRAND_NAME="My Site Account"
# SSO_BRAND_LOGO=/assets/img/logo.png

# ── Cross-Site Sync (optional — reports activity to HW hub) ─────────────
# SYNC_API_KEY=site_...
# SYNC_ACTIVITY_URL=https://hiphop.world/api/network/activity.php
# SYNC_PROFILE_URL=https://hiphop.world/api/network/profile-sync.php
