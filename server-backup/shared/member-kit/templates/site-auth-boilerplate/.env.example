# ── Member Kit Auth Configuration ──────────────────────────────────────────────
# Copy this to your site's .env and fill in the values.

# Site Identity
SITE_KEY=mysite
SITE_NAME="My Site Name"
SITE_LOGO=/assets/img/logo.png
SITE_PRIMARY_COLOR=#3B82F6

# Auth Mode (always 'independent' for non-HipHop sites)
MEMBER_MODE=independent

# Member Kit Paths
MEMBER_KIT_PATH=/home/hiphopwo/shared/member-kit
MEMBER_KIT_URL=/shared/member-kit

# Database (members table)
DB_HOST=localhost
DB_NAME=mydb
DB_USER=myuser
DB_PASSWORD=secret
DB_CHARSET=utf8mb4
MEMBER_TABLE_PREFIX=
MEMBER_TABLE=members
MEMBER_SESSION_KEY=member_id

# Google OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://mysite.com/api/auth/google-callback.php

# SMTP (for password reset emails)
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=contact@mysite.com
SMTP_PASSWORD=secret
SMTP_FROM=contact@mysite.com
SMTP_FROM_NAME="My Site"
