{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$version": "1.0.0",
  "$description": "Layer 1 — Core System Tokens. Shared across ALL brands. Never change per-theme.",

  "spacing": {
    "$description": "8px base grid system — universal across all brands",
    "0":   { "$value": "0", "$type": "dimension" },
    "1":   { "$value": "0.25rem", "$type": "dimension" },
    "2":   { "$value": "0.5rem", "$type": "dimension" },
    "3":   { "$value": "0.75rem", "$type": "dimension" },
    "4":   { "$value": "1rem", "$type": "dimension" },
    "5":   { "$value": "1.25rem", "$type": "dimension" },
    "6":   { "$value": "1.5rem", "$type": "dimension" },
    "8":   { "$value": "2rem", "$type": "dimension" },
    "10":  { "$value": "2.5rem", "$type": "dimension" },
    "12":  { "$value": "3rem", "$type": "dimension" },
    "16":  { "$value": "4rem", "$type": "dimension" },
    "20":  { "$value": "5rem", "$type": "dimension" },
    "24":  { "$value": "6rem", "$type": "dimension" }
  },

  "radius": {
    "$description": "Border radius — consistent across all brands",
    "sm":   { "$value": "6px", "$type": "dimension" },
    "md":   { "$value": "8px", "$type": "dimension" },
    "lg":   { "$value": "12px", "$type": "dimension", "$description": "Inputs, buttons" },
    "xl":   { "$value": "15px", "$type": "dimension", "$description": "Cards" },
    "2xl":  { "$value": "20px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },

  "motion": {
    "$description": "Animation timing — shared motion language across brands",
    "duration": {
      "fast":    { "$value": "150ms", "$type": "duration", "$description": "Micro-interactions (hover, focus)" },
      "normal":  { "$value": "250ms", "$type": "duration", "$description": "Standard transitions" },
      "slow":    { "$value": "350ms", "$type": "duration", "$description": "Entrance animations" },
      "reveal":  { "$value": "600ms", "$type": "duration", "$description": "Scroll reveal" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier", "$description": "Material standard" },
      "decel":    { "$value": "cubic-bezier(0.0, 0, 0.2, 1)", "$type": "cubicBezier", "$description": "Entering elements" },
      "accel":    { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier", "$description": "Exiting elements" },
      "bounce":   { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier", "$description": "Playful interactions" },
      "smooth":   { "$value": "cubic-bezier(0.25, 0.8, 0.25, 1)", "$type": "cubicBezier", "$description": "Default smooth" }
    }
  },

  "typography": {
    "$description": "Type scale — shared across brands (font families are per-theme)",
    "fontSize": {
      "xs":   { "$value": "0.75rem", "$type": "dimension" },
      "sm":   { "$value": "0.875rem", "$type": "dimension" },
      "base": { "$value": "1rem", "$type": "dimension" },
      "lg":   { "$value": "1.125rem", "$type": "dimension" },
      "xl":   { "$value": "1.25rem", "$type": "dimension" },
      "2xl":  { "$value": "1.5rem", "$type": "dimension" },
      "3xl":  { "$value": "2rem", "$type": "dimension" },
      "4xl":  { "$value": "clamp(2rem, 6vw, 4rem)", "$type": "dimension", "$description": "Hero title (fluid)" }
    },
    "fontWeight": {
      "normal":    { "$value": "400", "$type": "fontWeight" },
      "medium":    { "$value": "500", "$type": "fontWeight" },
      "semibold":  { "$value": "600", "$type": "fontWeight" },
      "bold":      { "$value": "700", "$type": "fontWeight" },
      "extrabold": { "$value": "800", "$type": "fontWeight" }
    },
    "lineHeight": {
      "tight":   { "$value": "1.1", "$type": "number" },
      "snug":    { "$value": "1.3", "$type": "number" },
      "normal":  { "$value": "1.5", "$type": "number" },
      "relaxed": { "$value": "1.6", "$type": "number" },
      "loose":   { "$value": "1.8", "$type": "number" }
    }
  },

  "breakpoint": {
    "$description": "Responsive breakpoints — all brands share the same grid",
    "sm":  { "$value": "640px", "$type": "dimension" },
    "md":  { "$value": "768px", "$type": "dimension" },
    "lg":  { "$value": "1024px", "$type": "dimension" },
    "xl":  { "$value": "1280px", "$type": "dimension" },
    "2xl": { "$value": "1536px", "$type": "dimension" }
  },

  "zIndex": {
    "$description": "Z-index scale — consistent layering across brands",
    "particles":  { "$value": "-1", "$type": "number" },
    "base":       { "$value": "0", "$type": "number" },
    "content":    { "$value": "1", "$type": "number" },
    "sticky":     { "$value": "10", "$type": "number" },
    "header":     { "$value": "50", "$type": "number" },
    "dropdown":   { "$value": "60", "$type": "number" },
    "modal":      { "$value": "100", "$type": "number" },
    "toast":      { "$value": "200", "$type": "number" }
  },

  "opacity": {
    "$description": "Opacity scale — shared across brands",
    "0":         { "$value": "0", "$type": "number" },
    "muted":     { "$value": "0.5", "$type": "number" },
    "secondary": { "$value": "0.6", "$type": "number" },
    "disabled":  { "$value": "0.5", "$type": "number" },
    "full":      { "$value": "1", "$type": "number" }
  },

  "shadow": {
    "$description": "Elevation shadows — structural, not brand-colored",
    "sm":   { "$value": "0 1px 2px rgba(0, 0, 0, 0.05)", "$type": "shadow" },
    "md":   { "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1)", "$type": "shadow" },
    "lg":   { "$value": "0 10px 15px -3px rgba(0, 0, 0, 0.1)", "$type": "shadow" },
    "xl":   { "$value": "0 20px 25px -5px rgba(0, 0, 0, 0.1)", "$type": "shadow" },
    "card":    { "$value": "0 4px 24px rgba(0, 0, 0, 0.3)", "$type": "shadow" },
    "tooltip": { "$value": "0 4px 12px rgba(0, 0, 0, 0.5)", "$type": "shadow" }
  },

  "semantic": {
    "$description": "Semantic status colors — WCAG AA validated, fixed across all themes",
    "success": { "$value": "#43B581", "$type": "color" },
    "error":   { "$value": "#F04747", "$type": "color" },
    "warning": { "$value": "#FFB800", "$type": "color" },
    "info":    { "$value": "#4ECDC4", "$type": "color" }
  }
}
